+<script setup>
+import { ref, computed, onMounted } from 'vue';
+import { useI18n } from 'vue-i18n';
+import { 
+  ThunderboltOutlined,
+  EditOutlined,
+  DeleteOutlined,
+  PlayCircleOutlined,
+  PlusOutlined,
